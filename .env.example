# =============================================================================
# Krishna Neupane Portfolio — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# Never commit .env.local — it is gitignored.
# Set the same variables in Vercel → Project → Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://krishnaneupane.com

# Google Search Console site verification (optional)
GOOGLE_VERIFICATION=

# -----------------------------------------------------------------------------
# Database (PostgreSQL / Vercel Postgres / Prisma)
# -----------------------------------------------------------------------------
DATABASE_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=postgresql://user:password@localhost:5432/portfolio
POSTGRES_HOST=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# -----------------------------------------------------------------------------
# Admin authentication
# Generate AUTH_SECRET: openssl rand -hex 32
# -----------------------------------------------------------------------------
AUTH_SECRET=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Optional admin UI hints (public, non-secret)
NEXT_PUBLIC_ADMIN_EMAIL=
NEXT_PUBLIC_POSTGRES_URL=

# -----------------------------------------------------------------------------
# GitHub — Reach & Stack stats, contributions, Code Canvas
# Create token: GitHub → Settings → Developer settings → Personal access tokens
# Scopes: public_repo (read), read:user
# -----------------------------------------------------------------------------
GITHUB_ACCESS_TOKEN=
GITHUB_USERNAME=krishna-commits

# -----------------------------------------------------------------------------
# ResearchGate — homepage ResearchGate Activity section
# No public API; set these from https://www.researchgate.net/profile/Krishna-Neupane/stats
# Used when live scrape is blocked.
# -----------------------------------------------------------------------------
RESEARCHGATE_RESEARCH_INTEREST_SCORE=
RESEARCHGATE_CITATIONS=
RESEARCHGATE_H_INDEX=
RESEARCHGATE_RECOMMENDATIONS=
RESEARCHGATE_TOTAL_READS=
RESEARCHGATE_READS=

# Optional read breakdown (leave 0 if not shown on ResearchGate stats page)
RESEARCHGATE_PUBLICATION_READS=0
RESEARCHGATE_FULLTEXT_READS=0
RESEARCHGATE_OTHER_READS=0
RESEARCHGATE_QUESTION_READS=0
RESEARCHGATE_ANSWER_READS=0

# -----------------------------------------------------------------------------
# Medium — homepage Medium reads (no public reads API)
# Update from https://medium.com/me/stats when logged in
# -----------------------------------------------------------------------------
MEDIUM_TOTAL_READS=
MEDIUM_TOTAL_POSTS=

# Optional: Medium session cookies for future stats scraping
MEDIUM_SID=
MEDIUM_UID=

# -----------------------------------------------------------------------------
# Contact form email (Resend)
# https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# File uploads (Vercel Blob)
# Vercel Dashboard → Storage → Blob → Create token
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=
NEXT_PUBLIC_BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# Cloudflare analytics (admin dashboard, optional)
# -----------------------------------------------------------------------------
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# -----------------------------------------------------------------------------
# Error monitoring — Sentry (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Analytics (optional — currently commented out in code)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=krishnaneupane.com
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://analytics.umami.is/script.js

# -----------------------------------------------------------------------------
# Node / Vercel (usually auto-set)
# -----------------------------------------------------------------------------
# NODE_ENV=development
# VERCEL=1
# NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=
